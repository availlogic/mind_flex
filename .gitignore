# ==================== Project-specific ====================
# Playwright artifacts (E2E test runner)
brain-hub-homepage/test-results/
brain-hub-homepage/playwright-report/
brain-hub-homepage/blob-report/
brain-hub-homepage/playwright/.cache/

# Vitest cache / coverage
brain-hub-homepage/coverage/
game-memory-flashmatrix/coverage/
backend/coverage/
backend/htmlcov/

# E2E staging tree (only created when Playwright runs locally — usually in /tmp,
# but listed defensively in case it ever leaks into the repo)
tests/e2e-stage/

# Orphan root-level Node manifests (apps have their own under their own dirs).
# The repo runtime is browser + Python + Postgres; no root wrangler/global deps.
# If these ever reappear, exclude them.
yarn.lock
pnpm-lock.yaml

# Per-app lockfiles under subprojects (app-specific) ARE tracked — do not
# add `brain-hub-homepage/package-lock.json` or
# `game-memory-flashmatrix/package-lock.json` here.

# Backend: keep `pyproject.toml` tracked; uv lockfiles should be tracked too.
# (Do not exclude `backend/uv.lock`.)

# Cloudflare tunnel runtime files (auto-generated by `cloudflared` tool;
# the *.json contains real TunnelSecret/TunnelID and MUST NEVER be committed).
# The canonical, sanitized sample lives at backend/cloudflared/config.example.yml.
cloudflared/*
!cloudflared/.gitkeep
*.cert.pem
*.key.pem
